# offline_packages/target.env
#
# Single source of truth for the offline bundle's BUILD PROFILE: the GPU class the
# bundle targets and the toolchain versions to gather. Sourced by every
# download_*.sh and install.sh script so they stay consistent.
#
# Default profile: NVIDIA GeForce RTX 4090 (Ada, compute capability sm_89),
# Ubuntu 22.04 / 24.04, Python 3.11, CUDA 12.8.
#
# Every value uses `=` (assign only if UNSET — note: not `:=`, so an explicit
# empty value like `TORCH_VERSION="" bash <script>` is respected, not overwritten).
# So an explicit `VAR=... bash <script>` on the command line always WINS over this
# file. Point at a different profile with `TARGET_ENV=/path/to/other.env`.

# NVIDIA driver major to gather as .deb. RTX 4090 runs on 535+; 570 is a recent,
# widely-available branch and matches scripts/install_online.sh.
: "${TARGET_DRIVER=570}"

# Python series (must satisfy pyproject `requires-python = >=3.11`).
: "${PYTHON_VERSION=3.11}"

# PyTorch wheel index. RTX 4090 (sm_89) is covered by every recent CUDA build;
# cu128 = CUDA 12.8, matching the online installer.
: "${TORCH_CUDA=cu128}"

# Pinned torch + torchaudio for reproducible bundles. sm_89 supports current
# releases, so this tracks a known-good version. Bump deliberately; set to ""
# to take whatever is newest on the index instead.
#
# NOTE: this pin targets RTX 4090. An older GPU whose latest wheel dropped support
# needs its own profile — e.g. a Volta/sm_70 V100 test box wants
# `TARGET_ENV=` overridden or `TORCH_CUDA=cu124 TORCH_VERSION=2.6.0` on the CLI.
: "${TORCH_VERSION=2.11.0}"

export TARGET_DRIVER PYTHON_VERSION TORCH_CUDA TORCH_VERSION
